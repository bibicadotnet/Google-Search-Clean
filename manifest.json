{
  "manifest_version": 3,
  "name": "Google Search Clean",
  "version": "1.0",
  "description": "Forces Google Search to default to the Web-only tab (udm=14) and strips tracking parameters",
  "icons": {
    "16": "images/icons/16.png",
    "32": "images/icons/32.png",
    "48": "images/icons/48.png",
    "128": "images/icons/128.png"
  },
  "chrome_settings_overrides": {
    "search_provider": {
      "name": "Google Search Clean",
      "keyword": "google.com",
      "search_url": "https://www.google.com/search?q={searchTerms}&udm=14",
      "suggest_url": "https://www.google.com/complete/search?output=chrome&q={searchTerms}",
      "favicon_url": "https://www.google.com/favicon.ico",
      "encoding": "UTF-8",
      "is_default": true
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/search*",
        "*://www.google.com.vn/search*",
        "*://www.google.com/travel/flights*",
        "*://www.google.com.vn/travel/flights*",
        "*://www.google.com/finance*",
        "*://www.google.com.vn/finance*",
        "*://www.google.com/webhp*",
        "*://www.google.com.vn/webhp*",
        "*://www.google.com/",
        "*://www.google.com.vn/"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_start"
    }
  ]
}